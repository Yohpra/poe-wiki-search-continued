{
    "name": "poe-wiki-search-continued",
    "version": "2.0.3",
    "description": "Stupid-simple wiki search for PoE!",
    "scripts": {
        "start": "web-ext run -s ./src",
        "build": "web-ext build -s ./src/ -a build --ignore-files **/*.spec.js",
